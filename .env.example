# Backend environment variables (example)
# Copy to `.env` and fill real values. Do NOT commit secrets.

# Server
PORT=5000
NODE_ENV=development

# CORS (set to your frontend URL in dev/prod)
CLIENT_URL=http://localhost:3000

# MongoDB
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.mongodb.net/dbname

# Session
SESSION_SECRET=change-me

# Newsletter/subscribe email (choose ONE option below)

# Option A: nodemailer `service` (Gmail / Google Workspace)
# NOTE: For Gmail/Google Workspace you usually must use an "App Password" (not your normal login password).


MAIL_SERVICE=Gmail
MAIL_USER=support@mycouponstock.com
MAIL_PASS=eqiorrwclqbszeen
MAIL_FROM=MyCouponStock <support@mycouponstock.com>

# Option B: SMTP (recommended for custom domain mail like support@mycouponstock.com)
# Examples:
# - Zoho: SMTP_HOST=smtp.zoho.in, SMTP_PORT=465, SMTP_SECURE=true
# - Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, SMTP_SECURE=true
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@example.com
# SMTP_PASS=your-password

